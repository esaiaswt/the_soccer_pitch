# =============================================================================
# Multi-Agent Team Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Pitch Server Connection ---
# Host and port of the Pitch server to connect to.
# Default: localhost:8000
PITCH_HOST=localhost
PITCH_PORT=8000

# --- NVIDIA API ---
# Your NVIDIA NIM API key (required, must be non-empty).
NVIDIA_API_KEY=

# --- LLM Model Configuration ---
# Coach model: stronger model for tactical analysis (e.g., 70B-class).
COACH_MODEL=meta/llama-3.3-70b-instruct

# Player model: lighter model for fast per-player decisions (8B-class or smaller).
PLAYER_MODEL=meta/llama-3.1-8b-instruct

# --- Timing Parameters ---
# Coaching frequency: how often (in seconds) the Coach issues new instructions.
# Valid range: 2 to 30 seconds. Default: 7
COACHING_FREQUENCY=7

# State Poller interval: how often (in seconds) to poll GET /api/state.
# Valid range: 0.1 to 10 seconds. Default: 1
POLL_INTERVAL=1

# --- Dashboard ---
# Streamlit port for the Team Dashboard.
# Valid range: 1024 to 65535. Leave empty for auto-assignment (scans 8501-8510).
STREAMLIT_PORT=

# --- Team Settings ---
# Team color: Red or Blue. Can also be set via the dashboard at runtime.
TEAM_COLOR=Red

# --- Coach Memory ---
# Maximum number of game state snapshots the Coach keeps in memory.
# Default: 50
COACH_MEMORY_SIZE=50
